# PocketSync — local development config
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
#
# GitHub Actions reads the same values from repository secrets:
#   Settings → Secrets and variables → Actions → New repository secret

# ── USER_CONFIG ──────────────────────────────────────────────────────────────
# Full USER_CONFIG object as a JSON string.
# Must be valid JSON (double quotes, no trailing commas).
USER_CONFIG={"householdName":"My Household","currency":"USD","timezone":"America/Los_Angeles","members":[{"name":"Member 1","email":"member1@example.com"},{"name":"Member 2","email":"member2@example.com"}],"accounts":[{"bank":"My Bank","name":"Checking – Primary","type":"Checking","owner":"Member 1"},{"bank":"My Bank","name":"Checking – Secondary","type":"Checking","owner":"Member 2"},{"bank":"My CC","name":"Card – Primary","type":"Credit Card","owner":"Member 1","creditLimit":10000}]}

# ── RULE_EMAILS ───────────────────────────────────────────────────────────────
# JSON array of emails allowed to read/write Firestore.
# Must match the emails in USER_CONFIG.members (plus any admin email).
RULE_EMAILS=["member1@example.com","member2@example.com"]

# ── FIREBASE_TOKEN ────────────────────────────────────────────────────────────
# CI token used by GitHub Actions to deploy.
# Generate once with:  firebase login:ci
# (only needed in GitHub Secrets, not for local firebase serve)
FIREBASE_TOKEN=your_firebase_ci_token_here
